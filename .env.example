# ─────────────────────────────────────────────────────────────────────
# Telos environment variables
# Copy to .env.local for local dev, set in Vercel for production.
# ─────────────────────────────────────────────────────────────────────

# Database (Neon) — required
# Get from: https://console.neon.tech → project → Connection Details
# Use the POOLED connection string (with -pooler in the host) for serverless.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.us-east-2.aws.neon.tech/telos?sslmode=require"

# Auth (JWT signing) — required
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-32-byte-random-string"

# Resend (transactional email) — required
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Telos <no-reply@telos.foundation>"

# Cloudflare R2 (proof + deliverable storage) — required
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# Bucket: create one called "telos-uploads" first.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxx"
R2_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_BUCKET="telos-uploads"
# Public dev URL (optional) — only needed if you want public read access for serving uploaded files.
# Otherwise we generate signed GET URLs at read time.
R2_PUBLIC_URL=""

# Cloudflare Turnstile (CAPTCHA) — required
# Get from: https://dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAAxxxxxxxxxxxxxxx"
TURNSTILE_SECRET_KEY="0x4AAAAAAAxxxxxxxxxxxxxxx"

# App URL — required (used in magic link emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin bootstrap — comma-separated emails that get the admin role on first sign-in.
# Add yourself here before deploying.
ADMIN_EMAILS="alvingregory10k@gmail.com"
